<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle configuration for SentinelRate / fluxguard.
    Rules derived from CLAUDE.md code style section:
      - Java 17 features are permitted
      - No Lombok — explicit getters/setters
      - Javadoc on all public methods
      - Max method length: 30 lines
      - No magic numbers — constants in dedicated class or enum
-->
<module name="Checker">

    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Enforce UTF-8 source files -->
    <module name="NewlineAtEndOfFile"/>

    <!-- Enforce no trailing whitespace -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="Line has trailing spaces."/>
    </module>

    <!-- Max line length: 120 chars (generous for Java 17 records / sealed interfaces) -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <module name="TreeWalker">

        <!-- Javadoc: all public methods must have Javadoc (CLAUDE.md rule). -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowMissingPropertyJavadoc" value="true"/>
        </module>

        <!-- Method length: max 30 lines (CLAUDE.md rule). -->
        <module name="MethodLength">
            <property name="max" value="30"/>
        </module>

        <!-- Magic numbers: use named constants; ignore common literals -1, 0, 1, and 2. -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreAnnotation" value="true"/>
            <property name="ignoreHashCodeMethod" value="true"/>
        </module>

        <!-- Import hygiene. -->
        <module name="UnusedImports"/>
        <module name="AvoidStarImport"/>
        <module name="RedundantImport"/>

        <!-- General code quality. -->
        <module name="EmptyBlock"/>
        <module name="NeedBraces"/>
        <module name="EqualsHashCode"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="StringLiteralEquality"/>
        <module name="UnnecessaryParentheses"/>
        <module name="VisibilityModifier">
            <property name="allowPublicFinalFields" value="true"/>
        </module>

        <!-- Naming conventions. -->
        <module name="ConstantName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="MethodName"/>
        <module name="PackageName"/>
        <module name="ParameterName"/>
        <module name="TypeName"/>

        <!-- Whitespace. -->
        <module name="WhitespaceAround"/>
        <module name="NoWhitespaceBefore"/>
        <module name="GenericWhitespace"/>

    </module>

</module>
